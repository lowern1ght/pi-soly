{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["esnext"],
    "types": ["node"],
    "skipLibCheck": true,
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": false,
    "allowImportingTsExtensions": true,
    "noEmitOnError": false
  },
  "include": [
    "*.ts",
    "mcp-only/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "__tests__",
    "vitest.config.ts"
  ]
}